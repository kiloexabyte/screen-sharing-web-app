{
	"name": "nuxt-app",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,vue}\"",
		"prettyCheck": "bunx prettier --check \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,vue}\"",
		"unit-test": "bunx vitest run tests/units",
		"integration-test": "bunx vitest run tests/integrations",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@primeuix/themes": "^1.1.2",
		"@primevue/forms": "^4.3.5",
		"livekit-client": "^2.5.7",
		"livekit-server-sdk": "^2.7.0",
		"moment": "^2.30.1",
		"nuxt": "^3.11.1",
		"primevue": "^4.3.5",
		"vue": "^3.4.21",
		"vue-router": "^4.3.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@nuxt/test-utils": "^3.14.3",
		"@primevue/nuxt-module": "^4.3.5",
		"@types/node": "^22.8.1",
		"@vue/test-utils": "^2.4.6",
		"autoprefixer": "^10.4.19",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-functional": "^9.0.4",
		"eslint-plugin-vue": "^10.8.0",
		"happy-dom": "^15.7.4",
		"postcss": "^8.4.38",
		"prettier": "^3.2.5",
		"prettier-plugin-tailwindcss": "^0.5.13",
		"tailwindcss": "^3.4.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^3.2.0",
		"vue-eslint-parser": "^10.4.0"
	},
	"prettier": {
		"semi": true,
		"singleQuote": false,
		"useTabs": true,
		"trailingComma": "all",
		"bracketSpacing": true,
		"arrowParens": "always",
		"plugins": [
			"prettier-plugin-tailwindcss"
		]
	}
}
